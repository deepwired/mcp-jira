# Copy this to .env and fill in your values.
# .env is gitignored — it will never be committed.

JIRA_INSTANCE=yourcompany
JIRA_USER_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your-scoped-token-here
JIRA_SCOPES=read:jira-work,write:jira-work,read:jira-user,read:me

# Optional: Cloud ID is auto-fetched from your instance if not set.
# Set this to skip the auto-fetch (faster startup, works offline).
# Find it at: https://yourcompany.atlassian.net/_edge/tenant_info
JIRA_CLOUD_ID=
